#App
NODE_ENV=development
PORT=3000

# Database (PostgreSQL via Prisma)
DATABASE_URL="postgresql://postgres:password@localhost:5432/filestorage"
# redis
REDIS_URL="redis://localhost:6379"

# JWT 
# JWT_SECRET=
# JWT_EXPIRES_IN="7d"

# Storage: S3 or MinIO 
STORAGE_DRIVER=s3                   # s3 | local
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=filestorage-dev

# MinIO local dev override
# S3_ENDPOINT=http://localhost:9000
# S3_FORCE_PATH_STYLE=true

#Upload limits 
MAX_FILE_SIZE_MB=500
SIGNED_URL_TTL_SECONDS=900          # 15 min download link expiry
CHUNK_SIZE_MB=10                    # multipart threshold
